# Supabase service-role key (server-side only — never expose this in the frontend)
SUPABASE_KEY=your_supabase_service_role_key_here

# The Supabase anon (public) key goes directly in web/index.html
# It is safe to expose because Row Level Security restricts writes.
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
